{
  "name": "deribit-mcp",
  "version": "1.0.0",
  "description": "MCP server for Deribit — options chains, greeks, volatility surface, portfolio analytics, and trading via Claude Desktop or any MCP client",
  "type": "module",
  "main": "dist/index.js",
  "bin": {
    "deribit-mcp": "dist/index.js"
  },
  "keywords": [
    "mcp",
    "deribit",
    "options",
    "crypto",
    "derivatives",
    "trading",
    "volatility",
    "greeks",
    "bitcoin",
    "ethereum"
  ],
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "git+https://github.com/schoeffeljp/deribit-mcp.git"
  },
  "author": "JP Schoeffel",
  "engines": {
    "node": ">=18.0.0"
  },
  "scripts": {
    "build": "tsc",
    "start": "node dist/index.js",
    "start:http": "MCP_TRANSPORT=http node dist/index.js",
    "dev": "tsc --watch",
    "test": "vitest run",
    "test:watch": "vitest"
  },
  "dependencies": {
    "@modelcontextprotocol/sdk": "^1.12.1",
    "zod": "^3.24.0"
  },
  "devDependencies": {
    "@types/node": "^22.0.0",
    "dotenv": "^17.3.1",
    "typescript": "^5.7.0",
    "vitest": "^3.2.4"
  }
}
