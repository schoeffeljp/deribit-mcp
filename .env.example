# Deribit API credentials — required for private endpoints (account, positions, trading)
# Mainnet: https://www.deribit.com/account/api
# Testnet: https://test.deribit.com/account/api
DERIBIT_CLIENT_ID=your_client_id
DERIBIT_CLIENT_SECRET=your_client_secret

# Set to "true" to use testnet (recommended for development/testing)
DERIBIT_TESTNET=true
